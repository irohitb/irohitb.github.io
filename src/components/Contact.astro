---
import { profile } from "../data/profile";
---

<div id="contact" style="margin-top:80px; padding:44px 0 64px; border-top:1px solid var(--border-08);">
  <div style="font-family:'Geist Mono',monospace; font-size:15px; margin-bottom:16px;">
    <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">contact</span><span
      style="color:var(--faint);">&gt;</span>
  </div>
  <h2 style="font-size:30px; font-weight:700; color:var(--text1); letter-spacing:-0.02em; line-height:1.12; margin-bottom:14px;">
    Got an interesting problem?<br />Let&rsquo;s talk about it.
  </h2>
  <p style="font-size:14px; color:var(--text-9); line-height:1.6; max-width:460px; margin-bottom:24px;">
    Always open to conversations about AI, agents, and product engineering — especially the kind without an obvious
    answer yet.
  </p>
  <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
    <a
      href={`mailto:${profile.email}`}
      style="display:inline-block; font-size:14px; font-weight:600; color:var(--btn-fg); background:var(--text1); padding:11px 22px; border-radius:8px;"
      >{profile.email} →</a
    >
    <a
      class="icon-link"
      href={profile.calendly}
      target="_blank"
      rel="noopener"
      style="display:inline-block; font-size:14px; font-weight:600; color:var(--text1); padding:11px 22px; border:1px solid var(--border-14); border-radius:8px;"
      >Book a 30-min call →</a
    >
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <button
        type="button"
        class="icon-link"
        data-copy={profile.whatsapp}
        title="Click to copy, then search it in WhatsApp"
        style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--text-9); padding:7px 12px; border:1px solid var(--border-12); border-radius:6px; background:transparent; cursor:pointer;"
      >
        <span data-copy-label>WhatsApp · {profile.whatsapp}</span>
      </button>
      <a
        class="icon-link"
        href={profile.socials.github}
        style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--text-9); padding:7px 12px; border:1px solid var(--border-12); border-radius:6px;"
        >GitHub</a
      >
      <a
        class="icon-link"
        href={profile.socials.x}
        style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--text-9); padding:7px 12px; border:1px solid var(--border-12); border-radius:6px;"
        >X</a
      >
      <a
        class="icon-link"
        href={profile.socials.linkedin}
        style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--text-9); padding:7px 12px; border:1px solid var(--border-12); border-radius:6px;"
        >LinkedIn</a
      >
      <a
        class="icon-link"
        href={profile.socials.npm}
        style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--text-9); padding:7px 12px; border:1px solid var(--border-12); border-radius:6px;"
        >npm</a
      >
    </div>
  </div>
</div>

<script is:inline>
  // Click-to-copy for any [data-copy] element (e.g. the WhatsApp username).
  // WhatsApp has no public username link, so copying the handle is how people
  // "connect" — copy, then search it in WhatsApp. Delegated so it covers the
  // hero icon and the contact pill.
  document.addEventListener("click", function (e) {
    var el = e.target.closest("[data-copy]");
    if (!el) return;
    e.preventDefault();
    try {
      navigator.clipboard.writeText(el.getAttribute("data-copy"));
    } catch (err) {}
    var label = el.querySelector("[data-copy-label]");
    if (label && !el.dataset.copied) {
      var orig = label.textContent;
      el.dataset.copied = "1";
      label.textContent = "Copied ✓";
      setTimeout(function () {
        label.textContent = orig;
        delete el.dataset.copied;
      }, 1400);
    }
  });
</script>
