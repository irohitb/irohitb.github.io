---
import { birthdayInfo, lifeStatic } from "../data/life";
import { getHealth } from "../data/health";
import { music } from "../data/music";
import { getContributions } from "../data/github";

const { age, daysUntil } = birthdayInfo();
const contributions = getContributions();
const health = getHealth();

const tiles = [
  { title: `🎂 ${age} years old`, sub: `Next birthday in ${daysUntil} days` },
  { title: `📍 ${lifeStatic.location}`, sub: lifeStatic.locationSub },
  {
    title: `💻 ${contributions.toLocaleString()} contributions`,
    sub: "On GitHub this year",
  },
  { title: `🎯 ${lifeStatic.focus}`, sub: lifeStatic.focusSub },
  { title: `🏋️ ${health.workoutsThisMonth} workouts`, sub: "Logged this month" },
  {
    title: `🔥 ${health.kcalBurnedThisMonth.toLocaleString()} kcal`,
    sub: "Burned this month",
  },
  {
    title: `🎧 ${music.nowPlaying.track}`,
    sub: `Currently listening · ${music.nowPlaying.artist}`,
  },
  { title: `👣 ${health.dailyStepsAvg} steps`, sub: "Daily average" },
];
---

<div id="life">
  <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:28px;">
    <div style="font-family:'Geist Mono',monospace; font-size:13px;">
      <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">life</span><span
        style="color:var(--faint);">&gt;</span>
    </div>
    <span style="font-size:11.5px; color:var(--muted);">live · Apple Health · GitHub · YouTube Music</span>
  </div>
  <div style="display:grid; grid-template-columns:repeat(4, 1fr); column-gap:32px; row-gap:32px;">
    {
      tiles.map((tile) => (
        <div>
          <div style="font-size:17px; font-weight:600; color:var(--text-e4); line-height:1.3;">{tile.title}</div>
          <div style="font-size:13px; color:var(--muted); margin-top:5px;">{tile.sub}</div>
        </div>
      ))
    }
  </div>
</div>
