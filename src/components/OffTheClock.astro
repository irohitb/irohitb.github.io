---
import { blogs, movies } from "../data/offTheClock";
import { music } from "../data/music";
---

<div>
  <div style="font-family:'Geist Mono',monospace; font-size:13px; margin-bottom:22px;">
    <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">off the clock</span><span
      style="color:var(--faint);">&gt;</span>
  </div>
  <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:48px; align-items:start;">
    <div style="min-width:0;">
      <div
        style="font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;"
      >
        📚 Reading
      </div>
      {
        blogs.map((b) => (
          <a
            href={b.href}
            target="_blank"
            rel="noopener"
            style="display:block; padding:13px 0; border-top:1px solid var(--border-07);"
          >
            <div style="font-size:14.5px; font-weight:500; color:var(--text-d4); line-height:1.4; margin-bottom:3px;">
              {b.title}
            </div>
            <div style="font-family:'Geist Mono',monospace; font-size:11.5px; color:var(--accent);">{b.source}</div>
          </a>
        ))
      }
    </div>

    <div style="min-width:0;">
      <div
        style="font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;"
      >
        🎬 Fav movies
      </div>
      {
        movies.map((m) => (
          <a
            href={m.trailer}
            target="_blank"
            rel="noopener"
            style="display:block; padding:13px 0; border-top:1px solid var(--border-07);"
          >
            <div style="font-size:14.5px; font-weight:500; color:var(--text-d4); line-height:1.4; margin-bottom:3px;">
              {m.title}
            </div>
            <div style="font-size:12px; color:var(--muted);">{m.meta} ↗</div>
          </a>
        ))
      }
    </div>

    <div style="min-width:0;">
      <div
        style="font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;"
      >
        🎵 Fav music
      </div>
      {
        music.topTracks.map((t) => (
          <a
            href={t.youtube}
            target="_blank"
            rel="noopener"
            style="display:block; padding:13px 0; border-top:1px solid var(--border-07);"
          >
            <div style="font-size:14.5px; font-weight:500; color:var(--text-d4); line-height:1.4; margin-bottom:3px;">
              {t.track}
            </div>
            <div style="font-size:12px; color:var(--muted);">{t.artist} ↗</div>
          </a>
        ))
      }
    </div>
  </div>
</div>
