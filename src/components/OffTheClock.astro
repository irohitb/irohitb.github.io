---
import { blogs, movies } from "../data/offTheClock";
import { music } from "../data/music";

// Thumbnail per blog = the site's favicon (reliable, no per-URL fetching).
const favicon = (url: string) => {
  try {
    return `https://www.google.com/s2/favicons?domain=${new URL(url).hostname}&sz=64`;
  } catch {
    return "";
  }
};
---

<div>
  <div style="font-family:'Geist Mono',monospace; font-size:15px; margin-bottom:22px;">
    <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">off the clock</span><span
      style="color:var(--faint);">&gt;</span>
  </div>
  <div class="offclock-grid" style="display:grid; grid-template-columns:repeat(3, 1fr); gap:48px; align-items:start;">
    <div style="min-width:0;">
      <div
        style="font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;"
      >
        🎬 Fav movies
      </div>
      {
        movies.map((m) => (
          <a
            href={m.trailer}
            target="_blank"
            rel="noopener"
            style="display:block; padding:13px 0;"
          >
            <span style="display:block; font-size:14.5px; font-weight:500; color:var(--text-d4); line-height:1.4; margin-bottom:3px;">
              {m.title} <span style="color:var(--muted); font-size:12.5px;">↗</span>
            </span>
            <span style="display:block; font-size:12px; color:var(--muted);">{m.meta}</span>
          </a>
        ))
      }
    </div>

    <div style="min-width:0;">
      <div
        style="font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;"
      >
        🎵 Fav music
      </div>
      {
        music.topTracks.map((t) => (
          <a
            href={t.youtube}
            target="_blank"
            rel="noopener"
            style="display:block; padding:13px 0;"
          >
            <span style="display:block; font-size:14.5px; font-weight:500; color:var(--text-d4); line-height:1.4; margin-bottom:3px;">
              {t.track} <span style="color:var(--muted); font-size:12.5px;">↗</span>
            </span>
            <span style="display:block; font-size:12px; color:var(--muted);">{t.artist}</span>
          </a>
        ))
      }
    </div>

    <div style="min-width:0;">
      <div
        style="font-size:11px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:6px;"
      >
        📚 Reading
      </div>
      {
        blogs.map((b) => (
          <a
            href={b.href}
            target="_blank"
            rel="noopener"
            style="display:flex; gap:12px; align-items:center; padding:13px 0;"
          >
            <span style="flex:none; width:32px; height:32px; border-radius:8px; border:1px solid var(--border-12); background:var(--node-bg); display:flex; align-items:center; justify-content:center; overflow:hidden;">
              <img src={favicon(b.href)} alt="" loading="lazy" style="width:18px; height:18px; object-fit:contain;" />
            </span>
            <span style="min-width:0;">
              <span style="display:block; font-size:14.5px; font-weight:500; color:var(--text1); line-height:1.4; margin-bottom:3px;">
                {b.title}
              </span>
              <span style="display:block; font-family:'Geist Mono',monospace; font-size:11.5px; color:var(--muted);">{b.source}</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</div>
