---
import { recommendations } from "../data/recommendations";

// Homepage shows the first few; the full list lives on /recommendations.
const featured = recommendations.slice(0, 3);
const initials = (name: string) =>
  name
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0])
    .join("")
    .toUpperCase();
---

<div style="flex:1.25; min-width:0;">
  <div style="display:flex; align-items:baseline; justify-content:space-between; gap:12px; margin-bottom:20px;">
    <div style="font-family:'Geist Mono',monospace; font-size:15px;">
      <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">recommendations</span><span
        style="color:var(--faint);">&gt;</span>
    </div>
    <a
      href="https://www.linkedin.com/in/irbhatia/details/recommendations"
      target="_blank"
      rel="noopener"
      style="font-size:11.5px; color:var(--muted); text-decoration:underline; text-underline-offset:2px; white-space:nowrap;"
      >LinkedIn &nearr;</a
    >
  </div>
  <div style="display:flex; flex-direction:column; gap:2px;">
    {
      featured.map((rec, i) => {
        const hasMore = rec.full.trim() !== rec.short.trim();
        return (
          <div
            class="rec-card"
            style="display:flex; gap:16px; padding:20px 0; border-top:1px solid var(--border-08);"
          >
            {rec.avatar ? (
              <img
                src={rec.avatar}
                style="flex:none; width:40px; height:40px; border-radius:50%; object-fit:cover;"
                alt=""
              />
            ) : (
              <span
                style="flex:none; width:40px; height:40px; border-radius:50%; border:1px solid var(--border-12); background:var(--node-bg); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; color:var(--muted2);"
                aria-hidden="true"
              >
                {initials(rec.name)}
              </span>
            )}
            <div style="flex:1; min-width:0;">
              {hasMore ? (
                <>
                  {/* short shown by default; checkbox reveals full on "Read more" */}
                  <input type="checkbox" id={`rec-${i}`} class="rec-toggle" hidden />
                  <p class="rec-quote rec-short">&ldquo;{rec.short}&rdquo;</p>
                  <p class="rec-quote rec-full">&ldquo;{rec.full}&rdquo;</p>
                  <label for={`rec-${i}`} class="rec-more">
                    <span class="more">Read more</span>
                    <span class="less">Show less</span>
                  </label>
                </>
              ) : (
                <p class="rec-quote">&ldquo;{rec.short}&rdquo;</p>
              )}
              <div style="font-size:12.5px; color:var(--muted);">
                <span style="color:var(--text-e4); font-weight:600;">{rec.name}</span>
                &nbsp;·&nbsp;{" "}
                {rec.title}
              </div>
            </div>
          </div>
        );
      })
    }
  </div>

  <a
    href="/recommendations"
    class="page-link"
    style="margin-top:16px; font-size:13px; font-weight:500; color:var(--text-9);"
    >View all recommendations &amp; endorsements &rarr;</a
  >
</div>

<style>
  .rec-quote {
    font-size: 15px;
    color: var(--text-c8);
    line-height: 1.65;
    margin-bottom: 10px;
  }

  /* full is hidden until the toggle is checked, then it swaps in for short */
  .rec-full {
    display: none;
  }
  .rec-toggle:checked ~ .rec-full {
    display: block;
  }
  .rec-toggle:checked ~ .rec-short {
    display: none;
  }

  .rec-more {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-9);
    text-decoration: underline;
    text-underline-offset: 2px;
    user-select: none;
  }

  .rec-more .less {
    display: none;
  }
  .rec-toggle:checked ~ .rec-more .more {
    display: none;
  }
  .rec-toggle:checked ~ .rec-more .less {
    display: inline;
  }
</style>
