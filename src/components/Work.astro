---
import { work } from "../data/work";
---

<div style="flex:1; min-width:0;">
  <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:20px;">
    <div style="font-family:'Geist Mono',monospace; font-size:15px;">
      <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">work</span><span
        style="color:var(--faint);">&gt;</span>
    </div>
    <span style="font-size:11.5px; color:var(--muted);">{work.length} most recent</span>
  </div>
  <div style="position:relative;">
    <div style="position:absolute; left:16px; top:24px; bottom:24px; width:1px; background:var(--border-12);"></div>
    {
      work.map((job) => (
        <a href={job.href} target="_blank" rel="noopener" style="position:relative; display:flex; align-items:center; gap:14px; padding:12px 0;">
          <span style="position:relative; z-index:1; flex:none; width:32px; height:32px; border-radius:8px; border:1px solid var(--border-12); background:var(--node-bg); display:flex; align-items:center; justify-content:center; overflow:hidden;">
            {job.logo ? (
              <img src={job.logo} style="width:16px;height:16px;object-fit:contain;" alt="" />
            ) : (
              <span style="color:var(--muted2); font-size:13px;">★</span>
            )}
          </span>
          <span style="flex:1; min-width:0;">
            <span style="display:block; font-size:14px; font-weight:600; color:var(--text-e4);">
              {job.company}
              {job.note && (
                <span style="font-weight:400; color:var(--muted2); font-size:11px;"> · {job.note}</span>
              )}
            </span>
            <span style="display:block; font-size:12px; color:var(--muted2);">{job.role}</span>
            {job.does && (
              <span style="display:block; font-size:11px; color:var(--muted); margin-top:2px;">
                {job.does}
              </span>
            )}
          </span>
          <span style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted); flex:none;">
            {job.year}
          </span>
        </a>
      ))
    }
  </div>

  <a
    href="/experience"
    class="page-link"
    style="margin-top:14px; font-size:13px; font-weight:500; color:var(--text-9);"
    >View experience &rarr;</a
  >
</div>
