---
import Base from "../layouts/Base.astro";
import Background from "../components/Background.astro";
import { experience } from "../data/experience";
import { profile } from "../data/profile";

const { summary, roles, highlights, education, skills } = experience;
---

<Base title="Rohit Bhatia — Experience">
  <div style="position:relative; min-height:100vh;">
    <Background />

    <div
      style="position:relative; z-index:1; max-width:820px; margin:0 auto; padding:56px 24px 96px;"
    >
      <!-- header -->
      <a
        href="/"
        class="nav-link"
        style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--muted); text-decoration:none;"
        >&larr; rohitbhatia.com</a
      >

      <div
        style="display:flex; align-items:baseline; justify-content:space-between; gap:16px; margin-top:20px;"
      >
        <div style="font-family:'Geist Mono',monospace; font-size:15px;">
          <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">experience</span
          ><span style="color:var(--faint);">&gt;</span>
        </div>
        <a
          href={profile.resumeUrl}
          target="_blank"
          rel="noopener"
          style="font-size:13px; font-weight:500; color:var(--text-9); text-decoration:underline; text-underline-offset:2px; white-space:nowrap;"
          >&darr; Résumé PDF</a
        >
      </div>

      <h1
        style="font-size:34px; font-weight:700; letter-spacing:-0.02em; color:var(--text1); margin:20px 0 12px;"
      >
        {profile.name}
      </h1>
      <p
        style="font-size:15px; line-height:1.7; color:var(--text-9); max-width:640px; margin:0;"
      >
        {summary}
      </p>

      <!-- roles -->
      <div style="margin-top:44px; display:flex; flex-direction:column; gap:32px;">
        {
          roles.map((r) => (
            <div style="display:flex; gap:16px;">
              <span style="flex:none; width:38px; height:38px; border-radius:9px; border:1px solid var(--border-12); background:var(--node-bg); display:flex; align-items:center; justify-content:center; overflow:hidden; margin-top:2px;">
                {r.logo ? (
                  <img src={r.logo} alt="" style="width:20px; height:20px; object-fit:contain;" />
                ) : (
                  <span style="color:var(--muted2); font-size:14px;">★</span>
                )}
              </span>

              <div style="flex:1; min-width:0;">
                <div style="display:flex; align-items:baseline; justify-content:space-between; gap:12px; flex-wrap:wrap;">
                  <div style="font-size:16px; font-weight:600; color:var(--text-e4);">
                    {r.href ? (
                      <a
                        href={r.href}
                        target="_blank"
                        rel="noopener"
                        style="color:inherit; text-decoration:none;"
                      >
                        {r.company}
                      </a>
                    ) : (
                      r.company
                    )}
                    {r.note && (
                      <span style="font-weight:400; color:var(--muted2); font-size:12px;"> · {r.note}</span>
                    )}
                  </div>
                  <span style="font-family:'Geist Mono',monospace; font-size:11.5px; color:var(--muted); white-space:nowrap;">
                    {r.period}
                  </span>
                </div>
                <div style="font-size:13px; color:var(--muted2); margin:2px 0 12px;">
                  {r.title} · {r.what}
                </div>
                <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:8px;">
                  {r.bullets.map((b) => (
                    <li style="display:flex; gap:10px; font-size:14px; line-height:1.6; color:var(--text-9);">
                      <span style="color:var(--faint); flex:none;">—</span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>

      <!-- highlights -->
      <div style="margin-top:48px;">
        <div style="font-family:'Geist Mono',monospace; font-size:15px; margin-bottom:14px;">
          <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">highlights</span
          ><span style="color:var(--faint);">&gt;</span>
        </div>
        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:8px;">
          {
            highlights.map((h) => (
              <li style="display:flex; gap:10px; font-size:14px; line-height:1.6; color:var(--text-9);">
                <span style="color:var(--faint); flex:none;">—</span>
                <span>{h}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- education -->
      <div style="margin-top:44px;">
        <div style="font-family:'Geist Mono',monospace; font-size:15px; margin-bottom:14px;">
          <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">education</span
          ><span style="color:var(--faint);">&gt;</span>
        </div>
        <div style="display:flex; align-items:baseline; justify-content:space-between; gap:12px; flex-wrap:wrap;">
          <div>
            <div style="font-size:15px; font-weight:600; color:var(--text-e4);">{education.school}</div>
            <div style="font-size:13px; color:var(--muted2);">{education.degree}</div>
          </div>
          <span style="font-family:'Geist Mono',monospace; font-size:11.5px; color:var(--muted);">
            {education.period}
          </span>
        </div>
      </div>

      <!-- skills -->
      <div style="margin-top:44px;">
        <div style="font-family:'Geist Mono',monospace; font-size:15px; margin-bottom:14px;">
          <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);">skills</span
          ><span style="color:var(--faint);">&gt;</span>
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          {
            skills.map((s) => (
              <span style="font-family:'Geist Mono',monospace; font-size:12px; color:var(--text-9); padding:5px 10px; border:1px solid var(--border-12); border-radius:6px;">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Base>
