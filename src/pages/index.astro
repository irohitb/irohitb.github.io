---
import Base from "../layouts/Base.astro";
import Background from "../components/Background.astro";
import Nav from "../components/Nav.astro";
import Now from "../components/Now.astro";
import Recommendations from "../components/Recommendations.astro";
import Work from "../components/Work.astro";
import Life from "../components/Life.astro";
import OffTheClock from "../components/OffTheClock.astro";
import Contact from "../components/Contact.astro";
---

<Base title="Rohit Bhatia — Portfolio">
  <div style="position:relative; min-height:100vh;">
    <Background />
    <Nav />

    <div style="position:relative; z-index:1; max-width:1260px; margin:0 auto; padding:64px 40px 0;">
      <Now />

      <div id="work" style="margin-top:84px; display:flex; gap:60px; align-items:flex-start;">
        <Recommendations />
        <Work />
      </div>

      <div style="margin-top:84px;">
        <Life />
      </div>

      <div style="margin-top:84px;">
        <OffTheClock />
      </div>

      <Contact />
    </div>
  </div>
</Base>
