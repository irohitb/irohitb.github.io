---
import Base from "../layouts/Base.astro";
import Background from "../components/Background.astro";
import Nav from "../components/Nav.astro";
import RecommendationsAgentView from "../components/RecommendationsAgentView.astro";
import { recommendations } from "../data/recommendations";
import { endorsements } from "../data/endorsements";

const initials = (name: string) =>
  name
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0])
    .join("")
    .toUpperCase();
---

<Base title="Rohit Bhatia — Recommendations">
  <div class="human-only" style="position:relative; min-height:100vh;">
    <Background />
    <Nav subpage />

    <div
      style="position:relative; z-index:1; max-width:1080px; margin:0 auto; padding:48px 24px 96px;"
    >
      <a
        href="/"
        class="page-link"
        style="font-size:13px; color:var(--muted); margin-bottom:28px;"
        >&larr; Back</a
      >

      <div class="recs-layout">
        {/* 60% — full written recommendations */}
        <section>
          <div
            style="display:flex; align-items:baseline; justify-content:space-between; gap:16px; margin-bottom:32px;"
          >
            <div style="font-family:'Geist Mono',monospace; font-size:15px;">
              <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);"
                >recommendations</span
              ><span style="color:var(--faint);">&gt;</span>
            </div>
            <a
              href="https://www.linkedin.com/in/irbhatia/details/recommendations"
              target="_blank"
              rel="noopener"
              style="font-size:11.5px; color:var(--muted); text-decoration:underline; text-underline-offset:2px; white-space:nowrap;"
              >{recommendations.length} on LinkedIn &nearr;</a
            >
          </div>

          <div style="display:flex; flex-direction:column; gap:28px;">
            {
              recommendations.map((r) => (
                <div style="display:flex; gap:16px;">
                  {r.avatar ? (
                    <img
                      src={r.avatar}
                      alt=""
                      style="flex:none; width:44px; height:44px; border-radius:50%; object-fit:cover; margin-top:2px;"
                    />
                  ) : (
                    <span
                      style="flex:none; width:44px; height:44px; border-radius:50%; border:1px solid var(--border-12); background:var(--node-bg); display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:600; color:var(--muted2); margin-top:2px;"
                      aria-hidden="true"
                    >
                      {initials(r.name)}
                    </span>
                  )}

                  <div style="flex:1; min-width:0;">
                    <div style="font-size:15px; font-weight:600; color:var(--text-e4);">
                      {r.name}
                    </div>
                    <div style="font-size:12.5px; color:var(--muted2); margin:1px 0 3px;">
                      {r.title}
                    </div>
                    {r.relationship && (
                      <div style="font-family:'Geist Mono',monospace; font-size:11px; color:var(--muted); margin-bottom:12px;">
                        {r.relationship}
                      </div>
                    )}
                    <p style="font-size:14.5px; line-height:1.7; color:var(--text-c8); margin:0;">
                      &ldquo;{r.full}&rdquo;
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        {/* 40% — lighter-weight endorsements / connections */}
        <aside>
          <div style="font-family:'Geist Mono',monospace; font-size:15px; margin-bottom:32px;">
            <span style="color:var(--faint);">&lt;/</span><span style="color:var(--accent);"
              >endorsements</span
            ><span style="color:var(--faint);">&gt;</span>
          </div>

          <div style="display:flex; flex-direction:column; gap:20px;">
            {
              endorsements.map((e) => (
                <div style="display:flex; gap:12px; align-items:flex-start;">
                  {e.avatar ? (
                    <img
                      src={e.avatar}
                      alt=""
                      style="flex:none; width:38px; height:38px; border-radius:50%; object-fit:cover;"
                    />
                  ) : (
                    <span
                      style="flex:none; width:38px; height:38px; border-radius:50%; border:1px solid var(--border-12); background:var(--node-bg); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:600; color:var(--muted2);"
                      aria-hidden="true"
                    >
                      {initials(e.name)}
                    </span>
                  )}
                  <div style="flex:1; min-width:0;">
                    <div style="font-size:13.5px; font-weight:600; color:var(--text-e4);">
                      {e.name}
                    </div>
                    <div style="font-size:11.5px; line-height:1.45; color:var(--muted2); margin-top:1px;">
                      {e.title}
                    </div>
                    {e.relationship && (
                      <div style="font-family:'Geist Mono',monospace; font-size:10.5px; color:var(--muted); margin-top:3px;">
                        {e.relationship}
                      </div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </aside>
      </div>
    </div>
  </div>

  <RecommendationsAgentView />
</Base>

<style>
  /* 60 / 40 split; stacks to a single column on narrow screens. */
  .recs-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 56px;
    align-items: start;
  }
  @media (max-width: 760px) {
    .recs-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
